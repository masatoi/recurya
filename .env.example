# recurya environment configuration example.
# Copy this file to `.env` and fill in real values.
# Never commit `.env` to git.

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=15434
POSTGRES_DB=recurya
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --- Web server ---
PORT=3000

# --- OAuth: Google ---
# Get these from https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${OAUTH_REDIRECT_BASE}/auth/google/callback
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# --- OAuth: GitHub ---
# Get these from https://github.com/settings/developers (OAuth Apps)
# Authorization callback URL: ${OAUTH_REDIRECT_BASE}/auth/github/callback
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# Base URL the OAuth providers redirect back to.
# Use http://localhost:3000 for local development; the public origin in prod.
OAUTH_REDIRECT_BASE=http://localhost:3000

# Comma-separated list of emails that should receive role=admin on OAuth login.
# Example: ADMIN_OAUTH_EMAIL=me@example.com,ops@example.com
ADMIN_OAUTH_EMAIL=

# --- OAuth dev stub (LOCAL ONLY) ---
# Setting OAUTH_DEV_STUB=1 short-circuits the OAuth flow:
#   - /auth/:provider/start redirects directly to the local /callback
#   - exchange-code returns "DEV-ACCESS-TOKEN" without HTTP
#   - fetch-userinfo returns OAUTH_DEV_EMAIL / OAUTH_DEV_NAME
# Safety gate: stub mode is silently ignored unless OAUTH_REDIRECT_BASE is
# unset, contains "localhost" / "127.0.0.1", or contains ".ngrok"
# (ngrok-free.app / ngrok.app / ngrok.io / ngrok.dev tunnels). A real
# production deploy with this flag accidentally set will NOT mint dev sessions.
# OAUTH_DEV_STUB=1
# OAUTH_DEV_EMAIL=dev@example.com
# OAUTH_DEV_NAME=Dev User
